#!/usr/bin/env bash
set -e

# baseup bootstrap installer
# Downloads baseup and installs it into ~/.base/bin by default.

BASEUP_HOME="${BASEUP_HOME:-$HOME/.base}"
BIN_DIR="${BASE_BIN_DIR:-$BASEUP_HOME/bin}"
ENV_FILE="$BASEUP_HOME/env"
BASEUP_REPO="${BASEUP_REPO:-base/base}"
BASEUP_REPO_REF="${BASEUP_REPO_REF:-main}"
BASEUP_HOST_BASE_URL="${BASEUP_HOST_BASE_URL:-https://raw.githubusercontent.com/${BASEUP_REPO}/${BASEUP_REPO_REF}/baseup}"
BASEUP_URL="${BASEUP_URL:-${BASEUP_HOST_BASE_URL}/baseup}"
INSTALL_TMP_FILE=""

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

info() {
    echo -e "${GREEN}info${NC}: $1"
}

warn() {
    echo -e "${YELLOW}warn${NC}: $1"
}

error() {
    echo -e "${RED}error${NC}: $1"
    exit 1
}

ensure_writable_destination() {
    local dst="$1"
    local parent

    if [[ -e "$dst" ]]; then
        [[ -w "$dst" ]] && return
    else
        parent="$(dirname "$dst")"
        [[ -w "$parent" ]] && return
    fi

    error "destination $dst is not writable; choose a user-writable BASE_BIN_DIR"
}

install_bin() {
    local src="$1"
    local dst="$2"
    local tmp_dst="$dst.new"

    ensure_writable_destination "$dst"

    if cp "$src" "$tmp_dst" 2>/dev/null && chmod +x "$tmp_dst" && mv -f "$tmp_dst" "$dst"; then
        :
    else
        rm -f "$tmp_dst" 2>/dev/null || true
        error "failed to install to $dst"
    fi
}

ensure_dir() {
    local dir="$1"
    local env_name="$2"

    if ! mkdir -p "$dir" 2>/dev/null; then
        error "failed to create $dir; choose a user-writable $env_name"
    fi
}

cleanup_install() {
    if [[ -n "${INSTALL_TMP_FILE:-}" ]]; then
        rm -f "$INSTALL_TMP_FILE"
    fi
}

write_env_files() {
    if [[ ! -f "$ENV_FILE" ]]; then
        printf '%s\n' "# base shell setup" "export PATH=\"$BIN_DIR:\$PATH\"" > "$ENV_FILE"
    fi
    if [[ ! -f "$ENV_FILE.fish" ]]; then
        printf '%s\n' "# base shell setup" "fish_add_path -g \"$BIN_DIR\"" > "$ENV_FILE.fish"
    fi
}

configure_shell() {
    local source_line=". \"$ENV_FILE\""
    local fish_source_line="source \"$ENV_FILE.fish\""
    local shell_configs=()
    local cfg
    local found_existing_config=0

    if [[ -n "${ZDOTDIR:-}" ]]; then
        shell_configs+=("$ZDOTDIR/.zshenv")
    fi

    if [[ -f "$HOME/.zshenv" ]] || [[ "$(basename "$SHELL")" == "zsh" ]]; then
        shell_configs+=("$HOME/.zshenv")
    fi

    if [[ -f "$HOME/.bashrc" ]] || [[ "$(basename "$SHELL")" == "bash" ]]; then
        shell_configs+=("$HOME/.bashrc")
    fi

    if [[ -f "$HOME/.bash_profile" ]]; then
        shell_configs+=("$HOME/.bash_profile")
    fi

    if [[ -f "$HOME/.profile" ]]; then
        shell_configs+=("$HOME/.profile")
    fi

    local unique_configs=()
    local seen=""
    for cfg in "${shell_configs[@]}"; do
        case "$seen" in
            *"|$cfg|"*) ;;
            *)
                seen="$seen|$cfg|"
                unique_configs+=("$cfg")
                ;;
        esac
    done

    local modified=0

    for cfg in "${unique_configs[@]}"; do
        [[ -f "$cfg" ]] || continue
        found_existing_config=1

        if grep -qF "$ENV_FILE" "$cfg" 2>/dev/null; then
            continue
        fi

        echo >> "$cfg"
        echo "# Added by baseup installer" >> "$cfg"
        echo "$source_line" >> "$cfg"
        info "Added Base to PATH in $cfg"
        modified=1
    done

    local fish_config="${XDG_CONFIG_HOME:-$HOME/.config}/fish/config.fish"
    if [[ -f "$fish_config" ]]; then
        found_existing_config=1
        if ! grep -qF "$ENV_FILE.fish" "$fish_config" 2>/dev/null; then
            echo >> "$fish_config"
            echo "# Added by baseup installer" >> "$fish_config"
            echo "$fish_source_line" >> "$fish_config"
            info "Added Base to PATH in $fish_config"
            modified=1
        fi
    fi

    if [[ $modified -eq 0 ]]; then
        if [[ $found_existing_config -eq 0 ]]; then
            info "No existing shell config file found; leaving PATH unchanged"
        else
            info "Base is already configured in your shell"
        fi
    fi
}

trap cleanup_install EXIT

main() {
    echo "Installing baseup..."
    echo ""

    ensure_dir "$BASEUP_HOME" "BASEUP_HOME"
    ensure_dir "$BIN_DIR" "BASE_BIN_DIR"

    INSTALL_TMP_FILE="$(mktemp 2>/dev/null || mktemp -t baseup)"

    info "Downloading baseup script..."
    if command -v curl >/dev/null 2>&1; then
        curl -#fL "$BASEUP_URL" -o "$INSTALL_TMP_FILE"
    elif command -v wget >/dev/null 2>&1; then
        wget --show-progress -q -O "$INSTALL_TMP_FILE" "$BASEUP_URL"
    else
        error "neither curl nor wget found"
    fi

    if ! head -n 1 "$INSTALL_TMP_FILE" | grep -q '^#!'; then
        error "downloaded file does not appear to be a valid script"
    fi

    if ! bash -n "$INSTALL_TMP_FILE" 2>/dev/null; then
        error "downloaded script has syntax errors"
    fi

    install_bin "$INSTALL_TMP_FILE" "$BIN_DIR/baseup"
    info "baseup installed to $BIN_DIR/baseup"

    write_env_files
    export PATH="$BIN_DIR:$PATH"

    configure_shell

    info "Running baseup to install release binaries..."
    echo ""

    if ! BASEUP_HOME="$BASEUP_HOME" BASE_BIN_DIR="$BIN_DIR" "$BIN_DIR/baseup"; then
        warn "Initial binary install failed, but baseup is installed at $BIN_DIR/baseup"
        warn "Retry later with: $BIN_DIR/baseup"
    fi

    echo ""
    local user_shell
    user_shell="$(basename "$SHELL")"
    if [[ "$user_shell" == "fish" ]]; then
        info "To get started, either restart your shell or run:"
        echo ""
        echo "  source $ENV_FILE.fish"
    else
        info "To get started, either restart your shell or run:"
        echo ""
        echo "  source $ENV_FILE"
    fi
    echo ""
}

main
